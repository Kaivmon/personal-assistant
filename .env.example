# Server
ASSISTANT_HOST=127.0.0.1
ASSISTANT_PORT=8765
ASSISTANT_DB_PATH=C:\PersonalAssistant\data\assistant.sqlite3
ASSISTANT_REPORT_DIR=C:\PersonalAssistant\data\reports
ASSISTANT_REPORT_TTL_SECONDS=7200

# OpenClaw local endpoint configuration
OPENCLAW_BASE_URL=http://127.0.0.1:3210
OPENCLAW_PROFILE=personal-assistant
OPENCLAW_DISCORD_ENABLED=true
OPENCLAW_DISCORD_BOT_TOKEN=
OPENCLAW_ALLOWED_DISCORD_USER_IDS=

# Primary provider: ChatGPT Plus through OpenClaw OAuth.
# Do not add OpenAI API keys. The assistant never consumes paid API credits.
OPENCLAW_CHATGPT_OAUTH_PROFILE=default
CHATGPT_USAGE_LIMIT_PER_WINDOW=80
CHATGPT_USAGE_USED=0
CHATGPT_WARN_REMAINING=20,5

# Fallback provider: Ollama on Beelink LAN only.
OLLAMA_BASE_URL=http://beelink:11434
OLLAMA_MODEL=llama3.1:8b

